# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to false in production to enable live email and LinkedIn publishing.
TEST_MODE=true

# ── Email (Phase 2) ───────────────────────────────────────────────────────────
# Gmail OAuth credentials — obtain from Google Cloud Console
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Where daily summaries are sent for approval
APPROVAL_EMAIL_RECIPIENT=your-email@example.com
# From address (must match authenticated Gmail account)
APPROVAL_EMAIL_SENDER=your-gmail@gmail.com

# ── AI (Phase 3) ─────────────────────────────────────────────────────────────
# Provider selection: xai, anthropic, gemini, or none (default)
AI_PROVIDER=none

# xAI / Grok — obtain at console.x.ai
XAI_API_KEY=

# Anthropic / Claude — obtain at console.anthropic.com
ANTHROPIC_API_KEY=

# Google / Gemini — obtain at aistudio.google.com
GEMINI_API_KEY=

# Optional: override the default model for the selected provider
# xAI default: grok-3-mini   Anthropic default: claude-haiku-4-5-20251001   Gemini default: gemini-2.5-flash
AI_MODEL=

# ── LinkedIn (Phase 4) ───────────────────────────────────────────────────────
# See LINKEDIN_SETUP.md for step-by-step instructions.
#
# 1. Create a LinkedIn Developer app: https://www.linkedin.com/developers/apps
# 2. Add "Share on LinkedIn" product to the app
# 3. Run: python scripts/linkedin_setup.py          (opens browser OAuth flow)
# 4. Run: python scripts/linkedin_setup.py --whoami (prints your author URN)
# 5. Set TEST_MODE=false when ready to go live
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
# URN of the person or organisation page to post as
# Run: python scripts/linkedin_setup.py --whoami   to get your URN
LINKEDIN_AUTHOR_URN=urn:li:person:REPLACE_ME

# ── NVD API (Phase 1 — optional, increases rate limits) ──────────────────────
# Register at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
# Relative path for JSON storage (created automatically)
DATA_DIR=data

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Collection window ─────────────────────────────────────────────────────────
# Hours to look back when collecting threat data
COLLECTION_WINDOW_HOURS=48
