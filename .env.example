# ─────────────────────────────────────────────────────────────────────────────
# CyberIntel Automation — environment configuration
#
# Copy this file to .env and fill in your credentials.
#
#   cp .env.example .env
#
# .env is excluded from git. Never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────


# ── Mode ──────────────────────────────────────────────────────────────────────
# Keep TEST_MODE=true while setting up and testing.
# The full pipeline runs but LinkedIn posts are saved locally instead of published.
# Set to false only when you are ready to go live.
TEST_MODE=true


# ── Email (required) ──────────────────────────────────────────────────────────
# Gmail OAuth2 credentials — obtain by running:
#   python scripts/gmail_setup.py
# Follow the browser prompt; the script prints the values to copy here.

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# The email address that receives the daily approval email.
APPROVAL_EMAIL_RECIPIENT=your-email@example.com

# The Gmail address the email is sent from.
# Must match the account you authenticated above.
APPROVAL_EMAIL_SENDER=your-gmail@gmail.com


# ── AI summarization (required — choose one provider) ────────────────────────
# Set AI_PROVIDER to one of: gemini | xai | anthropic | none
# "none" disables AI — the pipeline still collects data but skips summaries.
AI_PROVIDER=gemini

# Google Gemini — obtain at https://aistudio.google.com/app/apikey (free tier available)
GEMINI_API_KEY=

# xAI / Grok — obtain at https://console.x.ai
XAI_API_KEY=

# Anthropic / Claude — obtain at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the default model for the selected provider.
# Gemini default: gemini-2.5-flash
# xAI default:    grok-3-mini
# Anthropic:      claude-haiku-4-5-20251001
AI_MODEL=


# ── LinkedIn publishing (required for live publishing) ────────────────────────
# Obtain by running:
#   python scripts/linkedin_setup.py
# See LINKEDIN_SETUP.md for the full step-by-step guide.

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=

# The URN of the LinkedIn account to post as.
# Run:  python scripts/linkedin_setup.py --whoami
# to print your URN and copy it here.
LINKEDIN_AUTHOR_URN=urn:li:person:REPLACE_ME


# ── NVD API (optional) ───────────────────────────────────────────────────────
# Increases NVD CVE collection rate limits.
# Register free at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=


# ── Storage ───────────────────────────────────────────────────────────────────
# Directory for reports, audit logs, and collected data (created automatically).
DATA_DIR=data


# ── Logging ───────────────────────────────────────────────────────────────────
# One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# ── Collection window ─────────────────────────────────────────────────────────
# How many hours back to look when collecting threat intelligence.
# Default 48 hours covers the previous two days.
COLLECTION_WINDOW_HOURS=48
